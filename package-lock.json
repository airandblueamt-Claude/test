import { buildQnA } from './questions';
import type { QnA, Segment, TagKind, TranscriptDoc } from './types';

export interface ReportModel {
  fileName: string;
  date: string;
  durationSec: number;
  model: string;
  language: string;
  qna: QnA[];
  notes: Segment[];
  requirements: Segment[];
  decisions: Segment[];
  actions: Segment[];
  segments: Segment[];
}

function withTag(segments: Segment[], tag: TagKind): Segment[] {
  return segments.filter((s) => s.tags.includes(tag));
}

export function buildReport(doc: TranscriptDoc): ReportModel {
  return {
    fileName: doc.fileName,
    date: doc.createdAt,
    durationSec: doc.durationSec,
    model: doc.model,
    language: doc.language,
    qna: buildQnA(doc.segments),
    notes: withTag(doc.segments, 'note'),
    requirements: withTag(doc.segments, 'requirement'),
    decisions: withTag(doc.segments, 'decision'),
    actions: withTag(doc.segments, 'action'),
    segments: doc.segments,
  };
}
